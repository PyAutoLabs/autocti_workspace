{
    "type": "instance",
    "class_path": "autocti.clocker.one_d.Clocker1D",
    "arguments": {
        "prune_n_electrons": 1e-18,
        "time_start": 0,
        "window_start": 0,
        "roe": {
            "type": "instance",
            "class_path": "arcticpy.roe.ROEChargeInjection",
            "arguments": {
                "force_release_away_from_readout": true,
                "use_integer_express_matrix": false,
                "pixel_bounce_kA": 0.0,
                "pixel_bounce_omega": 1.0,
                "pixel_bounce_gamma": 1.0,
                "pixel_bounce_kv": 0.0,
                "empty_traps_between_columns": true,
                "dwell_times": {
                    "type": "ndarray",
                    "array": [
                        1.0
                    ],
                    "dtype": "float64"
                },
                "overscan_start": -1,
                "prescan_offset": 0
            }
        },
        "allow_negative_pixels": 1,
        "iterations": 5,
        "time_stop": -1,
        "window_stop": -1,
        "prune_frequency": 20,
        "verbosity": 0,
        "express": 5
    }
}